generator client {
  provider = "prisma-client-js"
  engineType = "classic"
}

datasource db {
  provider = "postgresql"
  // url = env("DATABASE_URL")
}

enum QuestionSource {
  category
  glossary_term
}

enum DailyProgressStatus {
  in_progress
  finished
  failed
}

enum TestContext {
  daily
  category
}

model User {
  id               String              @id @default(uuid()) @db.Uuid
  email            String              @unique
  password         String
  name             String
  lastName         String?
  createdAt        DateTime            @default(now())
  xpTotal          Int                 @default(0)
  streakDays       Int                 @default(0)
  lastActivityDate DateTime?           @db.Date
  dailyProgress    UserDailyProgress[]
  answers          UserAnswer[]
  termProgress     UserTermProgress[]
  categoryTestProgress UserCategoryTestProgress[]

  @@map("users")
}

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  slug      String     @unique
  title     String
  color     String
  terms     Term[]
  questions Question[]
  categoryTestProgress UserCategoryTestProgress[]

  @@map("categories")
}

model Term {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @db.Uuid
  term       String
  definition String
  isNew      Boolean  @default(false)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userProgress UserTermProgress[]

  @@index([categoryId])
  @@map("terms")
}

model Question {
  id          String              @id @default(uuid()) @db.Uuid
  categoryId  String?             @db.Uuid
  text        String
  difficulty  Int                 @default(1)
  source      QuestionSource
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  options     QuestionOption[]
  dailyLinks  DailyTestQuestion[]
  userAnswers UserAnswer[]

  @@index([categoryId])
  @@map("questions")
}

model QuestionOption {
  id         String       @id @default(uuid()) @db.Uuid
  questionId String       @db.Uuid
  text       String
  isCorrect  Boolean
  question   Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    UserAnswer[]

  @@index([questionId])
  @@map("question_options")
}

model DailyTest {
  id             String              @id @default(uuid()) @db.Uuid
  date           DateTime            @unique @db.Date
  seed           Int
  isActive       Boolean             @default(true)
  questions      DailyTestQuestion[]
  userProgresses UserDailyProgress[]

  @@map("daily_tests")
}

model DailyTestQuestion {
  id          String    @id @default(uuid()) @db.Uuid
  dailyTestId String    @db.Uuid
  questionId  String    @db.Uuid
  orderIndex  Int
  dailyTest   DailyTest @relation(fields: [dailyTestId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([dailyTestId, orderIndex])
  @@unique([dailyTestId, questionId])
  @@index([questionId])
  @@map("daily_test_questions")
}

model UserDailyProgress {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  dailyTestId String              @db.Uuid
  livesLeft   Int                 @default(3)
  score       Int                 @default(0)
  status      DailyProgressStatus @default(in_progress)
  startedAt   DateTime            @default(now())
  finishedAt  DateTime?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyTest   DailyTest           @relation(fields: [dailyTestId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyTestId])
  @@index([dailyTestId])
  @@map("user_daily_progress")
}

model UserAnswer {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  questionId       String         @db.Uuid
  selectedOptionId String         @db.Uuid
  isCorrect        Boolean
  answeredAt       DateTime       @default(now())
  testContext      TestContext
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuestionOption @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt])
  @@index([questionId])
  @@index([selectedOptionId])
  @@map("user_answers")
}

model UserCategoryTestProgress {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  categoryId     String   @db.Uuid
  stageKey       String
  score          Int
  totalQuestions Int
  passed         Boolean  @default(false)
  completedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, stageKey])
  @@index([userId, categoryId])
  @@map("user_category_test_progress")
}

model UserTermProgress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  termId    String   @db.Uuid
  learnedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([userId, termId])
  @@index([userId])
  @@map("user_term_progress")
}


